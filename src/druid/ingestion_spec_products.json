{
  "type": "kafka",
  "spec": {
    "dataSchema": {
      "dataSource": "ecommerce_product_metrics",
      "timestampSpec": {
        "column": "window_start",
        "format": "iso"
      },
      "dimensionsSpec": {
        "dimensions": [
          {"name": "product_id", "type": "string"},
          {"name": "category", "type": "string"}
        ]
      },
      "metricsSpec": [
        {"type": "count", "name": "count"},
        {"type": "longSum", "name": "view_count", "fieldName": "view_count"},
        {"type": "longSum", "name": "add_to_cart_count", "fieldName": "add_to_cart_count"},
        {"type": "longSum", "name": "wishlist_count", "fieldName": "wishlist_count"},
        {"type": "longSum", "name": "order_count", "fieldName": "order_count"},
        {"type": "longSum", "name": "unique_viewers", "fieldName": "unique_viewers"},
        {"type": "doubleSum", "name": "revenue", "fieldName": "revenue"},
        {"type": "doubleSum", "name": "view_to_order_conversion", "fieldName": "view_to_order_conversion_pct"}
      ],
      "granularitySpec": {
        "type": "uniform",
        "segmentGranularity": "HOUR",
        "queryGranularity": "MINUTE",
        "rollup": true
      }
    },
    "ioConfig": {
      "topic": "druid-ecommerce-metrics_products",
      "consumerProperties": {
        "bootstrap.servers": "localhost:9092",
        "group.id": "druid-consumer-products"
      },
      "taskCount": 1,
      "replicas": 1,
      "taskDuration": "PT1H",
      "inputFormat": {
        "type": "json"
      }
    },
    "tuningConfig": {
      "type": "kafka",
      "maxRowsInMemory": 100000
    }
  }
}
