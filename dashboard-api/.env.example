# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="E-Commerce Analytics API"
APP_VERSION="1.0.0"
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS='["http://localhost:3000","http://localhost:5173"]'

# ── Apache Druid (HTTP SQL API) ───────────────────────────────────────────────
DRUID_URL=http://localhost:8888
DRUID_TIMEOUT=30
DRUID_MAX_RETRIES=3
DRUID_BACKOFF_FACTOR=0.5

# ── ClickHouse — HTTP interface (health check) ────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_TIMEOUT=30

# ClickHouse — native driver (clickhouse-driver, faster bulk reads)
# Docker internal: host=clickhouse  port=9000
# Host access:     host=localhost   port=19000
CLICKHOUSE_HOST=localhost
CLICKHOUSE_NATIVE_PORT=19000     # external (host) access; use 9000 inside Docker
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ecom
CLICKHOUSE_POOL_SIZE=5
CLICKHOUSE_QUERY_TIMEOUT=60

# ── Apache Flink ──────────────────────────────────────────────────────────────
# External port 8082 maps to internal Flink REST port 8081
FLINK_URL=http://localhost:8082
FLINK_TIMEOUT=10
FLINK_MAX_RETRIES=3
FLINK_BACKOFF_FACTOR=0.3

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=flink-ecom-etl
KAFKA_CLEAN_TOPIC=ecommerce.events.clean.v1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=20

# Cache TTLs (seconds)
CACHE_TTL_KPIS=30
CACHE_TTL_TIMESERIES=60
CACHE_TTL_FUNNEL=300
CACHE_TTL_PRODUCTS=300
CACHE_TTL_LIVE=5
CACHE_TTL_FLINK=15
