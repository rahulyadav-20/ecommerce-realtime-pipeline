# =============================================================================
# config/prod.env.example — PRODUCTION TEMPLATE
# =============================================================================
#
# Active when:  APP_ENV=prod
#
# How to use:
#   1. Copy this file to  config/prod.env
#   2. Fill in real values (pull secrets from Vault / AWS Secrets Manager / GCP SM)
#   3. NEVER commit prod.env to version control — it is in .gitignore
#
# Recommended: inject secrets via environment variables in your CI/CD system
# rather than storing them in a file on disk.  The settings module gives
# environment variables the highest priority so the file can remain as a
# reference template.
# =============================================================================

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-prod-1:9092,kafka-prod-2:9092,kafka-prod-3:9092
SCHEMA_REGISTRY_URL=https://schema-registry.prod.example.com
KAFKA_RAW_TOPIC=ecommerce.events.raw.v1
KAFKA_CLEAN_TOPIC=ecommerce.events.clean.v1
KAFKA_DLQ_TOPIC=dlq.events
KAFKA_REPLICATION_FACTOR=3               # RF=3 for production durability
KAFKA_CONSUMER_GROUP_PREFIX=ecom-

# ── Flink ─────────────────────────────────────────────────────────────────────
FLINK_REST_URL=https://flink.prod.example.com:8081
FLINK_CHECKPOINT_DIR=s3://prod-flink-ckpt/ecom/
FLINK_SAVEPOINT_DIR=s3://prod-flink-savepoints/ecom/
FLINK_ETL_JOB_ID=                        # populated after job submission

# ── Object Storage (AWS S3 / MinIO cluster) ───────────────────────────────────
# For AWS S3: set MINIO_ENDPOINT to https://s3.amazonaws.com
# For a MinIO cluster: set to the cluster's load-balancer URL
MINIO_ENDPOINT=https://s3.prod.example.com
MINIO_ACCESS_KEY=<REPLACE_WITH_ACCESS_KEY>
MINIO_SECRET_KEY=<REPLACE_WITH_SECRET_KEY>
MINIO_WAREHOUSE_BUCKET=prod-iceberg-warehouse
MINIO_FLINK_CKPT_BUCKET=prod-flink-ckpt
MINIO_FLINK_SAVEPOINTS_BUCKET=prod-flink-savepoints
MINIO_DQ_RESULTS_BUCKET=prod-iceberg-warehouse

# ── ClickHouse ────────────────────────────────────────────────────────────────
# Use HTTPS in production.  Port 8443 is the TLS-enabled HTTP interface.
CLICKHOUSE_URL=https://clickhouse.prod.example.com:8443
CLICKHOUSE_USER=ecom_service              # not the default superuser
CLICKHOUSE_PASSWORD=<REPLACE_WITH_PASSWORD>
CLICKHOUSE_DATABASE=ecom

# ── Iceberg REST Catalog ──────────────────────────────────────────────────────
ICEBERG_REST_URL=https://catalog.prod.example.com
ICEBERG_WAREHOUSE=s3://prod-iceberg-warehouse/
ICEBERG_EVENTS_TABLE=warehouse.silver.events_clean

# ── Druid ─────────────────────────────────────────────────────────────────────
DRUID_REST_URL=https://druid.prod.example.com:8888
DRUID_DATASOURCE=ecommerce_events

# ── Pipeline tunables ─────────────────────────────────────────────────────────
TARGET_FILE_SIZE_MB=256                   # larger files in prod (more data/day)
MIN_FILE_SIZE_MB=64
SNAPSHOT_RETAIN_DAYS=14                   # keep 2 weeks of Iceberg snapshots

DQ_LOOKBACK_HOURS=1
DQ_SAMPLE_ROWS=50000                      # larger sample in prod
DQ_RESULTS_PREFIX=dq-results/great-expectations

FLINK_SAVEPOINT_RETAIN_DAYS=14
FLINK_SAVEPOINT_MIN_KEEP=3
FLINK_SAVEPOINT_TIMEOUT_SEC=600           # longer timeout in prod

GDPR_AUDIT_PREFIX=gdpr-audit

LATENCY_SAMPLE_RATE=1000                  # lighter sampling at prod volumes
ICEBERG_PLUGIN_VERSION=0.6.19

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
