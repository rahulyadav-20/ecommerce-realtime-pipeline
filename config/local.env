# =============================================================================
# config/local.env — LOCAL DEVELOPMENT (running from host machine)
# =============================================================================
#
# Active when:  APP_ENV=local  (this is the default when APP_ENV is unset)
#
# Use case: scripts and DAGs run directly on your laptop/desktop, connecting
# to services via the ports Docker exposes on localhost.
#
# MinIO S3 API is on 9002 (not 9000) because ClickHouse native takes 9000.
# Flink UI is on 8082 (not 8081) to avoid clash with Schema Registry.
# =============================================================================

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_RAW_TOPIC=ecommerce.events.raw.v1
KAFKA_CLEAN_TOPIC=ecommerce.events.clean.v1
KAFKA_DLQ_TOPIC=dlq.events
KAFKA_REPLICATION_FACTOR=2
KAFKA_CONSUMER_GROUP_PREFIX=ecom-

# ── Flink ─────────────────────────────────────────────────────────────────────
FLINK_REST_URL=http://localhost:8082
FLINK_CHECKPOINT_DIR=s3://flink-ckpt/ecom/
FLINK_SAVEPOINT_DIR=s3://flink-savepoints/ecom/
FLINK_ETL_JOB_ID=                          # fill after first submission

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://localhost:9002        # host:9002 → container:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_FLINK_CKPT_BUCKET=flink-ckpt
MINIO_FLINK_SAVEPOINTS_BUCKET=flink-savepoints
MINIO_DQ_RESULTS_BUCKET=warehouse

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ecom

# ── Iceberg REST Catalog ──────────────────────────────────────────────────────
ICEBERG_REST_URL=http://localhost:8181
ICEBERG_WAREHOUSE=s3://warehouse/
ICEBERG_EVENTS_TABLE=warehouse.silver.events_clean

# ── Druid ─────────────────────────────────────────────────────────────────────
DRUID_REST_URL=http://localhost:8888
DRUID_DATASOURCE=ecommerce_events

# ── Pipeline tunables ─────────────────────────────────────────────────────────
TARGET_FILE_SIZE_MB=128
MIN_FILE_SIZE_MB=10
SNAPSHOT_RETAIN_DAYS=7

DQ_LOOKBACK_HOURS=1
DQ_SAMPLE_ROWS=10000
DQ_RESULTS_PREFIX=dq-results/great-expectations

FLINK_SAVEPOINT_RETAIN_DAYS=7
FLINK_SAVEPOINT_MIN_KEEP=2
FLINK_SAVEPOINT_TIMEOUT_SEC=300

GDPR_AUDIT_PREFIX=gdpr-audit

LATENCY_SAMPLE_RATE=100
ICEBERG_PLUGIN_VERSION=0.6.19

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=                         # leave blank to disable Slack alerts
