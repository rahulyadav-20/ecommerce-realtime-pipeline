# =============================================================================
# config/docker.env — DOCKER (running inside containers on the bridge network)
# =============================================================================
#
# Active when:  APP_ENV=docker
#
# Use case: Airflow DAGs running inside the airflow-scheduler or airflow-worker
# container, or any ad-hoc container that needs to reach other services.
#
# Uses Docker-internal hostnames and container port numbers (not host-mapped).
# MinIO is at minio:9000 (internal) — not localhost:9002 (host-mapped).
# Flink REST API is at flink-jobmanager:8081 (internal) — not localhost:8082.
# =============================================================================

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka-1:29092,kafka-2:29093
SCHEMA_REGISTRY_URL=http://schema-registry:8081
KAFKA_RAW_TOPIC=ecommerce.events.raw.v1
KAFKA_CLEAN_TOPIC=ecommerce.events.clean.v1
KAFKA_DLQ_TOPIC=dlq.events
KAFKA_REPLICATION_FACTOR=2
KAFKA_CONSUMER_GROUP_PREFIX=ecom-

# ── Flink ─────────────────────────────────────────────────────────────────────
FLINK_REST_URL=http://flink-jobmanager:8081
FLINK_CHECKPOINT_DIR=s3://flink-ckpt/ecom/
FLINK_SAVEPOINT_DIR=s3://flink-savepoints/ecom/
FLINK_ETL_JOB_ID=

# ── MinIO / S3 ───────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000           # internal Docker hostname
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_WAREHOUSE_BUCKET=warehouse
MINIO_FLINK_CKPT_BUCKET=flink-ckpt
MINIO_FLINK_SAVEPOINTS_BUCKET=flink-savepoints
MINIO_DQ_RESULTS_BUCKET=warehouse

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=ecom

# ── Iceberg REST Catalog ──────────────────────────────────────────────────────
ICEBERG_REST_URL=http://iceberg-rest:8181
ICEBERG_WAREHOUSE=s3://warehouse/
ICEBERG_EVENTS_TABLE=warehouse.silver.events_clean

# ── Druid ─────────────────────────────────────────────────────────────────────
DRUID_REST_URL=http://druid-router:8888
DRUID_DATASOURCE=ecommerce_events

# ── Pipeline tunables (same across environments) ──────────────────────────────
TARGET_FILE_SIZE_MB=128
MIN_FILE_SIZE_MB=10
SNAPSHOT_RETAIN_DAYS=7

DQ_LOOKBACK_HOURS=1
DQ_SAMPLE_ROWS=10000
DQ_RESULTS_PREFIX=dq-results/great-expectations

FLINK_SAVEPOINT_RETAIN_DAYS=7
FLINK_SAVEPOINT_MIN_KEEP=2
FLINK_SAVEPOINT_TIMEOUT_SEC=300

GDPR_AUDIT_PREFIX=gdpr-audit

LATENCY_SAMPLE_RATE=100
ICEBERG_PLUGIN_VERSION=0.6.19

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=
