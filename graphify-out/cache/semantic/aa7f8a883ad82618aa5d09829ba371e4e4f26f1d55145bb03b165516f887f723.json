ing the consumer."}], "edges": [{"source": "02_kafka_engine_kafka_errors_mv", "target": "02_kafka_engine_events_kafka", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "line 197", "weight": 1.0}, {"source": "02_kafka_engine_kafka_errors_mv", "target": "02_kafka_engine_kafka_errors", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "line 191", "weight": 1.0}, {"source": "02_kafka_engine_events_mv", "target": "02_kafka_engine_events_kafka", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "line 247", "weight": 1.0}, {"source": "02_kafka_engine_events_mv", "target": "001_create_events_local_events_local", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "line 225", "weight": 1.0}, {"source": "02_kafka_engine_events_kafka", "target": "rationale_kafka_three_object_pipeline", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "lines 14-41", "weight": 1.0}, {"source": "rationale_replacingmergetree_dedup", "target": "rationale_kafka_three_object_pipeline", "relation": "conceptually_related_to", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "lines 38-41", "weight": 0.85}, {"source": "02_kafka_engine_events_mv", "target": "rationale_kafka_three_object_pipeline", "relation": "rationale_for", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "clickhouse/02_kafka_engine.sql", "source_location": "lines 206-223", "weight": 0.85}], "hyperedges": [{"id": "clickhouse_kafka_ingestion_pipeline", "label": "ClickHouse Ka