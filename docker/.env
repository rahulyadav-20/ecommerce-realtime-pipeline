# =============================================================================
# E-Commerce Realtime Pipeline — Docker Compose Environment Variables
# =============================================================================
#
# Usage:
#   Docker Compose automatically loads this file when it is named `.env`
#   and lives in the same directory as docker-compose.yml.
#
#   Variables defined here override defaults in the compose file.
#   Override on the command line:
#     KAFKA_BROKER_1_PORT=19092 docker compose up
#
# Security:
#   DO NOT commit credentials to version control in a shared/production repo.
#   Use Docker secrets or a secrets manager for any environment beyond local dev.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# HOST PORT MAPPINGS
# Change a port here if it conflicts with another service on your machine.
# ─────────────────────────────────────────────────────────────────────────────

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BROKER_1_PORT=9092
KAFKA_BROKER_2_PORT=9093
# Phase-1 compose has a third broker (KRaft mode):
KAFKA_BROKER_3_PORT=9094

SCHEMA_REGISTRY_PORT=8081
SCHEMA_REGISTRY_UI_PORT=8086
KAFKA_CONNECT_PORT=8083
KAFKA_UI_PORT=8085

# ── Flink ──────────────────────────────────────────────────────────────────────
FLINK_UI_PORT=8082

# ── Druid ──────────────────────────────────────────────────────────────────────
# Druid router / SQL console
DRUID_PORT=8888

# ── ClickHouse ─────────────────────────────────────────────────────────────────
# HTTP interface + Play UI (/play)
CLICKHOUSE_HTTP_PORT=8123
# Native binary protocol (JDBC, clickhouse-client)
# NOTE: 9000 is taken by ClickHouse; MinIO S3 API is on 9002 instead.
CLICKHOUSE_NATIVE_PORT=9000
# ClickHouse management UI (ch-ui)
CLICKHOUSE_UI_PORT=8124

# ── MinIO ──────────────────────────────────────────────────────────────────────
# Web console
MINIO_CONSOLE_PORT=9001
# S3-compatible API (mapped from container port 9000 → host 9002)
# host:9000 is occupied by ClickHouse native protocol
MINIO_S3_PORT=9002

# ── Iceberg REST Catalog ────────────────────────────────────────────────────────
ICEBERG_REST_PORT=8181

# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW_PORT=8080

# ── ELK Stack ──────────────────────────────────────────────────────────────────
ELASTICSEARCH_HTTP_PORT=9200
ELASTICSEARCH_TRANSPORT_PORT=9300
LOGSTASH_BEATS_PORT=5044
LOGSTASH_MONITORING_PORT=9600
KIBANA_PORT=5601


# ─────────────────────────────────────────────────────────────────────────────
# KAFKA CLUSTER SETTINGS
# ─────────────────────────────────────────────────────────────────────────────

# Random base64 string — uniquely identifies the cluster.
# Generate a new one: openssl rand -base64 16 | tr -d '='
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# Replication factor for user topics
KAFKA_REPLICATION_FACTOR=2
# Min in-sync replicas — keeps producing while one broker is down
KAFKA_MIN_ISR=1
# Default number of partitions per topic
KAFKA_NUM_PARTITIONS=12
# Log retention: 7 days
KAFKA_RETENTION_HOURS=168
# Compression for all topics (zstd = best ratio for JSON/Avro)
KAFKA_COMPRESSION_TYPE=zstd

# Schema Registry compatibility level applied to newly created subjects
# FULL_TRANSITIVE = must be compatible with ALL previous versions both ways
SCHEMA_REGISTRY_COMPAT=FULL_TRANSITIVE


# ─────────────────────────────────────────────────────────────────────────────
# FLINK
# ─────────────────────────────────────────────────────────────────────────────

# Slots per TaskManager (raise for more parallelism per container)
FLINK_TM_SLOTS=4
# Checkpoint interval in milliseconds
FLINK_CHECKPOINT_INTERVAL_MS=30000
# RocksDB incremental checkpoints (true = only changed SST files per checkpoint)
FLINK_ROCKSDB_INCREMENTAL=true
# S3 checkpoint bucket (MinIO internal endpoint)
FLINK_CHECKPOINT_DIR=s3://flink-ckpt/ecom/
FLINK_SAVEPOINT_DIR=s3://flink-savepoints/ecom/


# ─────────────────────────────────────────────────────────────────────────────
# MINIO / S3 CREDENTIALS
# Shared by: Flink (checkpoints), Iceberg REST Catalog, Kafka Connect (Iceberg sink),
#            Airflow DAGs (audit logs, DQ results)
# ─────────────────────────────────────────────────────────────────────────────

MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# MinIO internal Docker hostname:port (used by containers)
MINIO_ENDPOINT_INTERNAL=http://minio:9000
# MinIO host-facing endpoint (used by scripts run from the host machine)
MINIO_ENDPOINT_HOST=http://localhost:9002

# Bucket names (created by minio-setup on first boot)
MINIO_BUCKET_WAREHOUSE=warehouse
MINIO_BUCKET_FLINK_CKPT=flink-ckpt
MINIO_BUCKET_FLINK_SAVEPOINTS=flink-savepoints


# ─────────────────────────────────────────────────────────────────────────────
# CLICKHOUSE
# ─────────────────────────────────────────────────────────────────────────────

CLICKHOUSE_DB=ecom
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
# Memory cap for the server JVM-equivalent (set in config.xml; shown here for reference)
CLICKHOUSE_MAX_MEMORY_GB=4
# Iceberg Kafka consumer group (used in 02_kafka_engine.sql)
CLICKHOUSE_CONSUMER_GROUP=clickhouse-ecom-events


# ─────────────────────────────────────────────────────────────────────────────
# DRUID
# ─────────────────────────────────────────────────────────────────────────────

DRUID_POSTGRES_DB=druid
DRUID_POSTGRES_USER=druid
DRUID_POSTGRES_PASSWORD=druid
# Druid datasource name used in the Kafka supervisor spec
DRUID_DATASOURCE=ecommerce_events


# ─────────────────────────────────────────────────────────────────────────────
# ICEBERG REST CATALOG
# ─────────────────────────────────────────────────────────────────────────────

# REST catalog base URL (internal Docker hostname)
ICEBERG_REST_URL_INTERNAL=http://iceberg-rest:8181
# REST catalog base URL (host-facing, for scripts run from the host)
ICEBERG_REST_URL_HOST=http://localhost:8181
# Primary warehouse path (S3 bucket)
ICEBERG_WAREHOUSE=s3://warehouse/
# Default Iceberg table identifier for the events table
ICEBERG_EVENTS_TABLE=warehouse.silver.events_clean


# ─────────────────────────────────────────────────────────────────────────────
# AIRFLOW
# ─────────────────────────────────────────────────────────────────────────────

AIRFLOW_POSTGRES_DB=airflow
AIRFLOW_POSTGRES_USER=airflow
AIRFLOW_POSTGRES_PASSWORD=airflow

# Airflow admin credentials (created by airflow-init on first boot)
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# Fernet key for encrypting connection passwords at rest.
# Generate a new one: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=RiZ4PqTCKGR0DvOlR0yB6MJwxaO_6yJ9R8J2v5fXdoI=

# Webserver secret key (Flask sessions).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_SECRET_KEY=ecom-pipeline-secret

# Executor — LocalExecutor runs tasks as subprocesses of the scheduler.
# Switch to CeleryExecutor (+ add Redis) for multi-node scaling.
AIRFLOW_EXECUTOR=LocalExecutor

# Slot limit for LocalExecutor
AIRFLOW_PARALLELISM=8


# ─────────────────────────────────────────────────────────────────────────────
# ELASTICSEARCH / ELK
# ─────────────────────────────────────────────────────────────────────────────

# Heap for Elasticsearch JVM (rule: no more than 50% of available RAM, max 30 GB)
ES_JAVA_OPTS=-Xms2g -Xmx2g
# Heap for Logstash JVM
LS_JAVA_OPTS=-Xms1g -Xmx1g

# ELK Stack version (all three must match)
ELK_VERSION=8.17.0


# ─────────────────────────────────────────────────────────────────────────────
# KAFKA CONNECT / ICEBERG SINK
# ─────────────────────────────────────────────────────────────────────────────

# Tabular Iceberg connector version installed by install-connectors.sh
ICEBERG_PLUGIN_VERSION=0.6.19

# Kafka Connect consumer group (internal coordination topics prefix)
CONNECT_GROUP_ID=connect-cluster

# Iceberg sink connector consumer group
ICEBERG_CONSUMER_GROUP=cg-iceberg-sink-events

# Set to "true" once the image is pre-baked with the plugin to skip download
CONNECT_SKIP_HUB_INSTALL=false


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — External integrations (leave blank to disable)
# ─────────────────────────────────────────────────────────────────────────────

# Slack incoming webhook URL for DQ alerts and GDPR notifications
# Create at: https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# Flink job ID (set after first submission; used by flink_savepoint_rotation DAG)
# Get it with: curl http://localhost:8082/jobs/overview | jq '.jobs[].jid'
FLINK_ETL_JOB_ID=
