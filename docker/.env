# =============================================================================
# E-Commerce Pipeline — Environment Variables
# Copy to .env and adjust before running docker compose
# =============================================================================

# ---------- Ports (change if any conflict with host services) ----------
KAFKA_BROKER_1_PORT=9092
KAFKA_BROKER_2_PORT=9093
KAFKA_BROKER_3_PORT=9094
SCHEMA_REGISTRY_PORT=8081
FLINK_UI_PORT=8082
KAFKA_UI_PORT=8085

# ---------- Kafka ----------
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk   # base64 random, change per env
KAFKA_REPLICATION_FACTOR=3
KAFKA_MIN_ISR=2
KAFKA_NUM_PARTITIONS=12
KAFKA_RETENTION_HOURS=168                    # 7 days

# ---------- Flink ----------
FLINK_TM_SLOTS=4
FLINK_CHECKPOINT_INTERVAL_MS=30000

# ---------- Credentials ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------- Schema Registry ----------
SCHEMA_REGISTRY_COMPAT=FULL_TRANSITIVE
