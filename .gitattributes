# Normalise all text files to LF in the repo; checkout as-is on any OS
* text=auto eol=lf

# Force LF for shell scripts (must not have CRLF on Linux/Docker)
*.sh    text eol=lf
*.bash  text eol=lf

# Force LF for config / YAML / JSON / SQL
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.conf  text eol=lf
*.env   text eol=lf

# Binary — never touch line endings
*.jar   binary
*.class binary
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary
